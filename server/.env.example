# --- MongoDB Atlas Configuration ---
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?appName=AppName
MONGO_URL=your_mongodb_uri
MONGO_DB=ops

# --- Redis Configuration ---
# For development: redis://127.0.0.1:6379
# For production: Use managed Redis (ElastiCache, Redis Cloud, etc.)
REDIS_URL=redis://127.0.0.1:6379

# --- Authentication (Auth.js compatible JWT) ---
# Generate a secure secret: openssl rand -base64 48
JWT_SECRET=your-secret-key-here-generate-with-openssl
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d

# --- Server Configuration ---
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# --- CORS Configuration ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001

# --- Tenant Configuration ---
# For single-tenant setup, specify the default tenant name
DEFAULT_TENANT=gharpayy

# --- Super Admin Boostrap ---
# Default credentials used when no super admin exists. Override for production.
# SUPER_ADMIN_EMAIL=superadmin@gharpayy.com
# SUPER_ADMIN_PASSWORD=superadmin#gharpayy
# SUPER_ADMIN_NAME=Gharpayy Super Admin
#
# IMPORTANT: In production, set SUPERVISOR_ADMIN_EMAIL and SUPERVISOR_ADMIN_PASSWORD
# to strong, unique credentials. The defaults here are for local dev only.

# --- Logging ---
# Options: error, warn, info, debug, trace
LOG_LEVEL=info
