{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "zod": ["node_modules/zod"]
    }
  },
  "include": ["src/**/*", "../src/contracts/**/*"],
  "exclude": ["src/scripts/generate-html-audit.ts", "src/scripts/generate-local-audit.ts"]
}
